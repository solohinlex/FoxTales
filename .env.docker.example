# FoxTales AI — Docker configuration
# Скопируйте этот файл в .env и настройте переменные

# ─── Путь к контенту ───────────────────────────────────────
# Путь к папке с контентом (персонажи, главы, лор)
# По умолчанию: ./content
CONTENT_PATH=./content

# ─── Веб-интерфейс ──────────────────────────────────────────
# Порт для веб-интерфейса Gradio
WEB_PORT=7860

# ─── Embedding модель ──────────────────────────────────────
# Модель для эмбеддинга (используется с локальным Ollama)
EMBED_MODEL=nomic-embed-text

# ─── API для основной модели ───────────────────────────────
# API ключ для LLM (OpenAI или совместимый)
API_KEY=your_key_here

# Base URL для API (OpenAI или совместимый сервер)
API_BASE=https://api.openai.com/v1

# Название модели для генерации ответов
MODEL_NAME=gpt-4o

# ─── Опционально: кастомный URL Ollama ─────────────────────
# Если Ollama работает на другом порту/хосте
# EMBED_BASE_URL=http://localhost:11434